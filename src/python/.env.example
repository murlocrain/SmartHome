# ========== 项目基本信息 ==========
PROJECT_NAME=Smart Home IoT Platform
VERSION=1.0.0
API_V1_PREFIX=/api/v1

# ========== JWT 认证 ==========
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ========== CORS ==========
CORS_ORIGINS=*

# ========== 华为云 IoTDA ==========
HUAWEI_IOTDA_ENABLED=true
HUAWEI_IOTDA_REST_ENABLED=false
SYNC_INTERVAL=30

HUAWEI_IOTDA_REST_ENDPOINT=iotda.cn-north-4.myhuaweicloud.com
HUAWEI_IOTDA_APP_ENDPOINT=
HUAWEI_IOTDA_AK=
HUAWEI_IOTDA_SK=
HUAWEI_IOTDA_PROJECT_ID=
HUAWEI_IOTDA_INSTANCE_ID=

HUAWEI_IOTDA_MQTT_ENDPOINT=
HUAWEI_IOTDA_PORT=8883
HUAWEI_IOTDA_DEVICE_ID=
HUAWEI_IOTDA_USERNAME=
HUAWEI_IOTDA_PASSWORD=
HUAWEI_IOTDA_CLIENT_ID=
HUAWEI_IOTDA_USE_TLS=true

# ========== 数据库 ==========
# sqlite 或 mysql
DATABASE_TYPE=mysql
DATABASE_PATH=smart_home.db

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=smart_home

# ========== AI 智能体 ==========
AI_ENABLED=false
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat
AI_TEMPERATURE=0.7
AI_TIMEOUT=30

x);color:#94a3b8}.main-content{margin-top:.4vh;display:flex;flex-direction:column;gap:.8vh}.middle-section{display:flex;flex-direction:column;gap:.8vh}.chart-card{background:rgba(255,255,255,.05);border-radius:.8vw;padding:1vh 1vw;border:1rpx solid rgba(255,255,255,.05)}.full-width{width:100%}.card-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:.5vh}.card-title{font-size:clamp(13px,1.1vw,18px);font-weight:700;color:#fff}.card-subtitle{font-size:clamp(10px,.8vw,14px);color:#64748b}.legend{display:flex;gap:.6vw;flex-wrap:wrap}.legend-item{display:flex;align-items:center;gap:.3vw;font-size:clamp(10px,.8vw,13px);color:#94a3b8}.legend-item .line{width:1.2vw;height:.2vh;border-radius:1px}.legend-item .dot{width:.5vw;height:.5vw;min-width:6px;min-height:6px;border-radius:50%}.chart-body{position:relative;height:22vh;min-height:120px;display:flex;align-items:flex-start}.chart-body.dual-axis{flex-direction:row}.chart-area{position:relative;flex:1;height:18.5vh;min-height:100px}.axis-left,.axis-right{position:relative;width:3.5vw;min-width:36px;height:18.5vh;min-height:100px;flex-shrink:0}.chart-svg{position:absolute;top:0;left:0;width:100%;height:100%}.y-axis-label{position:absolute;font-size:clamp(9px,.7vw,12px);color:#64748b;text-align:right;padding-right:.3vw;transform:translateY(50%)}.axis-right .y-axis-label{text-align:left;padding-left:.3vw;padding-right:0}.axis-bottom{position:absolute;bottom:0;left:3.5vw;right:3.5vw;height:3vh}.axis-bottom .axis-label{position:absolute;transform:translate(-50%);font-size:clamp(9px,.7vw,12px);color:#64748b}.scene-legend{display:flex;gap:.6vw;margin-top:.4vh;flex-wrap:wrap}.scene-legend-item{display:flex;align-items:center;gap:.3vw;font-size:clamp(10px,.8vw,13px);color:#94a3b8}.scene-legend-item .dot{width:.5vw;height:.5vw;min-width:6px;min-height:6px;border-radius:50%}.scene-legend-item .name{font-size:clamp(10px,.8vw,13px)}.bottom-section{display:flex;flex-direction:column;gap:.8vh}.heatmap-card{flex:1}.heatmap-body{display:flex;flex-direction:column;gap:.1vh}.heatmap-row{display:flex;align-items:center}.heatmap-row.labels{border-bottom:1rpx solid rgba(255,255,255,.08);padding-bottom:.3vh;margin-bottom:.1vh}.heatmap-cell{flex:1;height:1.6vh;min-height:14px;border-radius:.2vw;display:flex;align-items:center;justify-content:center;font-size:clamp(8px,.65vw,11px)}.heatmap-cell.hour-label{width:2vw;min-width:18px;flex:none;color:#64748b;font-size:clamp(8px,.7vw,12px)}.heatmap-cell.day-label{color:#64748b;font-size:clamp(8px,.7vw,12px)}.heatmap-dot{color:#fff;font-size:clamp(8px,.7vw,12px)}.heatmap-legend{display:flex;align-items:center;gap:.4vw;margin-top:.4vh}.legend-label{font-size:clamp(9px,.7vw,12px);color:#64748b}.legend-bar{display:flex;flex:1;height:.6vh;min-height:5px;border-radius:.3vh;overflow:hidden}.legend-seg{flex:1}.right-bottom{display:flex;flex-direction:column;gap:.8vh}.pie-card{flex:1}.pie-body{display:flex;align-items:center;gap:1vw}.pie-svg{width:16vh;height:16vh;min-width:90px;min-height:90px;flex-shrink:0}.pie-legend{display:flex;flex-direction:column;gap:.4vh}.pie-legend-item{display:flex;align-items:center;gap:.3vw;font-size:clamp(10px,.8vw,13px)}.pie-legend-item .dot{width:.5vw;height:.5vw;min-width:6px;min-height:6px;border-radius:50%}.pie-legend-item .name{color:#94a3b8;flex:1}.pie-legend-item .value{color:#cbd5e1;font-weight:700}.timeline-card{flex:1}.timeline-row{display:flex;align-items:center;margin-bottom:.8vh}.timeline-date{width:3.5vw;min-width:44px;font-size:clamp(10px,.8vw,13px);color:#94a3b8;flex-shrink:0}.timeline-track{flex:1;height:2vh;min-height:18px;background:rgba(255,255,255,.05);border-radius:.5vh;position:relative}.timeline-marker{position:absolute;bottom:-.3vh;transform:translate(-50%);display:flex;flex-direction:column;align-items:center}.marker-line{width:1px;height:2.2vh;background:rgba(255,255,255,.1)}.marker-label{font-size:clamp(8px,.6vw,11px);color:#64748b;margin-top:.1vh}.timeline-event{position:absolute;top:-.5vh;transform:translate(-50%);display:flex;flex-direction:column;align-items:center}.event-icon{font-size:clamp(9px,.7vw,12px)}.event-time{font-size:clamp(7px,.55vw,10px);color:#94a3b8}.state-log-card{margin-top:0}.state-log-item{display:flex;align-items:center;padding:.6vh .8vw;background:rgba(255,255,255,.03);border-radius:.6vw;margin-bottom:.4vh;gap:.6vw}.log-time{font-size:clamp(10px,.85vw,14px);color:#94a3b8;flex-shrink:0}.log-state{display:flex;gap:.8vw}.log-item{display:flex;align-items:center;gap:.2vw;font-size:clamp(10px,.85vw,14px)}.log-item .icon{font-size:clamp(10px,.8vw,14px)}.log-item .on{color:#22c55e}.log-item .off{color:#94a3b8}.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.6);z-index:1000;display:flex;align-items:center;justify-content:center;padding:2vw}.modal-content{background:#1e293b;border-radius:1.2vw;padding:1.5vh 1.5vw;width:90%;max-width:500px}.modal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:1vh}.modal-title{font-size:clamp(15px,1.3vw,20px);font-weight:700;color:#fff}.modal-close{font-size:clamp(15px,1.3vw,20px);color:#94a3b8;padding:.4vw}.detail-date{text-align:center;margin-bottom:1vh}.detail-day{font-size:clamp(13px,1.1vw,18px);color:#fff;font-weight:700;display:block}.detail-hour{font-size:clamp(11px,.9vw,15px);color:#94a3b8;margin-top:.1vh;display:block}.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:.6vw}.detail-card{background:rgba(255,255,255,.05);border-radius:.7vw;padding:.8vh .8vw;text-align:center}.detail-icon{font-size:clamp(15px,1.3vw,22px);display:block;margin-bottom:.3vh}.detail-label{font-size:clamp(10px,.8vw,14px);color:#94a3b8;display:block}.detail-value{font-size:clamp(13px,1.1vw,18px);font-weight:700;color:#fff;display:block;margin-top:.1vh}.detail-info{text-align:center;margin-top:.6vh}.info-text{font-size:clamp(10px,.85vw,14px);color:#64748b}

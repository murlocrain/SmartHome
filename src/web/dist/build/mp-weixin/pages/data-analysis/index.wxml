<view class="page"><view class="status-bar" style="{{'padding-top:' + e}}"><view class="header"><view class="logo"><text class="logo-icon">📊</text><text class="app-name">数据分析看板</text></view><view class="header-actions"><view class="nav-btn" bindtap="{{a}}"><text>🔮 预警</text></view><view class="date-range" bindtap="{{c}}"><text class="date-text">{{b}}</text><text class="date-arrow">▼</text></view><view class="export-btn" bindtap="{{d}}"><text>导出报表</text></view></view></view></view><view class="status-cards"><view class="status-card temp"><text class="card-icon">🌡️</text><view class="card-info"><text class="card-value">{{f}}°C</text><text class="card-label">当前温度</text></view></view><view class="status-card humidity"><text class="card-icon">💧</text><view class="card-info"><text class="card-value">{{g}}%</text><text class="card-label">当前湿度</text></view></view><view class="status-card light"><text class="card-icon">💡</text><view class="card-info"><text class="card-value">{{h}}</text><text class="card-label">当前光照</text></view></view><view class="status-card person"><text class="card-icon">{{i}}</text><view class="card-info"><text class="card-value">{{j}}</text><text class="card-label">人员状态</text></view></view><view class="status-card scene"><text class="card-icon">🏠</text><view class="card-info"><text class="card-value">{{k}}</text><text class="card-label">当前场景</text></view></view></view><view class="main-content"><view class="middle-section"><view class="chart-card full-width"><view class="card-header"><text class="card-title">环境参数变化</text><view class="legend"><view class="legend-item"><view class="line" style="background:#f59e0b"></view>温度 (°C)</view><view class="legend-item"><view class="line" style="background:#3b82f6"></view>湿度 (%)</view><view class="legend-item"><view class="line" style="background:#10b981"></view>光照 (lux)</view></view></view><view class="chart-body dual-axis"><view class="axis-left"><text wx:for="{{l}}" wx:for-item="val" wx:key="b" class="y-axis-label" style="{{'bottom:' + val.c}}">{{val.a}}</text></view><view class="chart-area"><svg wx:if="{{D}}" u-s="{{['d']}}" class="chart-svg" u-i="db392a32-0" bind:__l="__l" u-p="{{D}}"><defs u-s="{{['d']}}" u-i="db392a32-1,db392a32-0" bind:__l="__l"><linear-gradient wx:if="{{o}}" u-s="{{['d']}}" id="tempGradient" u-i="db392a32-2,db392a32-1" bind:__l="__l" u-p="{{o}}"><stop wx:if="{{m}}" u-i="db392a32-3,db392a32-2" bind:__l="__l" u-p="{{m}}"/><stop wx:if="{{n}}" u-i="db392a32-4,db392a32-2" bind:__l="__l" u-p="{{n}}"/></linear-gradient><linear-gradient wx:if="{{r}}" u-s="{{['d']}}" id="humidityGradient" u-i="db392a32-5,db392a32-1" bind:__l="__l" u-p="{{r}}"><stop wx:if="{{p}}" u-i="db392a32-6,db392a32-5" bind:__l="__l" u-p="{{p}}"/><stop wx:if="{{q}}" u-i="db392a32-7,db392a32-5" bind:__l="__l" u-p="{{q}}"/></linear-gradient><linear-gradient wx:if="{{v}}" u-s="{{['d']}}" id="lightGradient" u-i="db392a32-8,db392a32-1" bind:__l="__l" u-p="{{v}}"><stop wx:if="{{s}}" u-i="db392a32-9,db392a32-8" bind:__l="__l" u-p="{{s}}"/><stop wx:if="{{t}}" u-i="db392a32-10,db392a32-8" bind:__l="__l" u-p="{{t}}"/></linear-gradient></defs><line wx:for="{{w}}" wx:for-item="i" wx:key="a" u-i="{{i.b}}" bind:__l="__l" u-p="{{i.c}}"/><polygon wx:if="{{x}}" u-i="db392a32-12,db392a32-0" bind:__l="__l" u-p="{{x}}"/><polyline wx:if="{{y}}" u-i="db392a32-13,db392a32-0" bind:__l="__l" u-p="{{y}}"/><polygon wx:if="{{z}}" u-i="db392a32-14,db392a32-0" bind:__l="__l" u-p="{{z}}"/><polyline wx:if="{{A}}" u-i="db392a32-15,db392a32-0" bind:__l="__l" u-p="{{A}}"/><polygon wx:if="{{B}}" u-i="db392a32-16,db392a32-0" bind:__l="__l" u-p="{{B}}"/><polyline wx:if="{{C}}" u-i="db392a32-17,db392a32-0" bind:__l="__l" u-p="{{C}}"/></svg></view><view class="axis-right"><text wx:for="{{E}}" wx:for-item="val" wx:key="b" class="y-axis-label" style="{{'bottom:' + val.c}}">{{val.a}}</text></view><view class="axis-bottom"><text wx:for="{{F}}" wx:for-item="label" wx:key="b" class="axis-label" style="{{'left:' + label.c}}">{{label.a}}</text></view></view></view><view class="chart-card full-width"><view class="card-header"><text class="card-title">活动强度与场景</text><view class="legend"><view class="legend-item"><view class="line" style="background:#6366f1"></view>活动强度</view></view></view><view class="chart-body"><view class="chart-area"><svg wx:if="{{O}}" u-s="{{['d']}}" class="chart-svg" u-i="db392a32-18" bind:__l="__l" u-p="{{O}}"><defs u-s="{{['d']}}" u-i="db392a32-19,db392a32-18" bind:__l="__l"><linear-gradient wx:if="{{I}}" u-s="{{['d']}}" id="activityGradient" u-i="db392a32-20,db392a32-19" bind:__l="__l" u-p="{{I}}"><stop wx:if="{{G}}" u-i="db392a32-21,db392a32-20" bind:__l="__l" u-p="{{G}}"/><stop wx:if="{{H}}" u-i="db392a32-22,db392a32-20" bind:__l="__l" u-p="{{H}}"/></linear-gradient></defs><line wx:for="{{J}}" wx:for-item="i" wx:key="a" u-i="{{i.b}}" bind:__l="__l" u-p="{{i.c}}"/><polygon wx:if="{{K}}" u-i="db392a32-24,db392a32-18" bind:__l="__l" u-p="{{K}}"/><polyline wx:if="{{L}}" u-i="db392a32-25,db392a32-18" bind:__l="__l" u-p="{{L}}"/><circle wx:for="{{M}}" wx:for-item="pt" wx:key="a" u-i="{{pt.b}}" bind:__l="__l" u-p="{{pt.c}}"/><circle wx:for="{{N}}" wx:for-item="pt" wx:key="a" u-i="{{pt.b}}" bind:__l="__l" u-p="{{pt.c}}"/></svg></view><view class="axis-bottom"><text wx:for="{{P}}" wx:for-item="label" wx:key="b" class="axis-label" style="{{'left:' + label.c}}">{{label.a}}</text></view></view><view class="scene-legend"><view wx:for="{{Q}}" wx:for-item="item" wx:key="c" class="scene-legend-item"><view class="dot" style="{{'background:' + item.a}}"></view><text class="name">{{item.b}}</text></view></view></view></view><view class="bottom-section"><view class="chart-card heatmap-card"><view class="card-header"><text class="card-title">24小时活动热力图</text><text class="card-subtitle">点击时段查看详情</text></view><view class="heatmap-body"><view class="heatmap-row labels"><text class="heatmap-cell hour-label"></text><text wx:for="{{R}}" wx:for-item="d" wx:key="b" class="heatmap-cell day-label">{{d.a}}</text></view><view wx:for="{{S}}" wx:for-item="h" wx:key="c" class="heatmap-row"><text class="heatmap-cell hour-label">{{h.a}}h</text><view wx:for="{{h.b}}" wx:for-item="val" wx:key="b" class="heatmap-cell" style="{{'background:' + val.c}}" bindtap="{{val.d}}"><text wx:if="{{val.a}}" class="heatmap-dot">●</text></view></view><view class="heatmap-legend"><text class="legend-label">低</text><view class="legend-bar"><view wx:for="{{T}}" wx:for-item="i" wx:key="a" class="legend-seg" style="{{'background:' + i.b}}"></view></view><text class="legend-label">高</text></view></view></view><view class="right-bottom"><view class="chart-card pie-card"><view class="card-header"><text class="card-title">场景分布</text></view><view class="pie-body"><svg wx:if="{{V}}" u-s="{{['d']}}" class="pie-svg" u-i="db392a32-28" bind:__l="__l" u-p="{{V}}"><g wx:for="{{U}}" wx:for-item="seg" wx:key="c" u-s="{{['d']}}" u-i="{{seg.d}}" bind:__l="__l"><path wx:if="{{seg.b}}" u-i="{{seg.a}}" bind:__l="__l" u-p="{{seg.b}}"/></g></svg><view class="pie-legend"><view wx:for="{{W}}" wx:for-item="item" wx:key="d" class="pie-legend-item"><view class="dot" style="{{'background:' + item.a}}"></view><text class="name">{{item.b}}</text><text class="value">{{item.c}}%</text></view></view></view></view><view class="chart-card timeline-card"><view class="card-header"><text class="card-title">每日作息时间线</text></view><view class="timeline-body"><view wx:for="{{X}}" wx:for-item="day" wx:key="o" class="timeline-row"><text class="timeline-date">{{day.a}}</text><view class="timeline-track"><view wx:for="{{day.b}}" wx:for-item="h" wx:key="b" class="timeline-marker" style="{{'left:' + h.c}}"><text class="marker-line"></text><text class="marker-label">{{h.a}}h</text></view><view wx:if="{{day.c}}" class="timeline-event" style="{{'left:' + day.e}}"><text class="event-icon">🚶</text><text class="event-time">{{day.d}}</text></view><view wx:if="{{day.f}}" class="timeline-event" style="{{'left:' + day.h}}"><text class="event-icon">🏠</text><text class="event-time">{{day.g}}</text></view><view wx:if="{{day.i}}" class="timeline-event" style="{{'left:' + day.k}}"><text class="event-icon">😴</text><text class="event-time">{{day.j}}</text></view><view wx:if="{{day.l}}" class="timeline-event" style="{{'left:' + day.n}}"><text class="event-icon">☀️</text><text class="event-time">{{day.m}}</text></view></view></view></view></view></view></view><view class="chart-card state-log-card"><view class="card-header"><text class="card-title">灯光/电机状态切换记录</text></view><view class="state-log-body"><view wx:for="{{Y}}" wx:for-item="log" wx:key="h" class="state-log-item"><text class="log-time">{{log.a}}</text><view class="log-state"><text wx:if="{{log.b}}" class="log-item"><text class="icon">💡</text><text class="{{log.d}}">{{log.c}}</text></text><text wx:if="{{log.e}}" class="log-item"><text class="icon">⚙️</text><text class="{{log.g}}">{{log.f}}</text></text></view></view></view></view></view><custom-tab-bar wx:if="{{Z}}" u-i="db392a32-31" bind:__l="__l" u-p="{{aa}}"/><custom-tab-bar wx:if="{{ab}}" u-i="db392a32-32" bind:__l="__l" u-p="{{ac}}"/><view wx:if="{{ad}}" class="modal-overlay" bindtap="{{aq}}"><view class="modal-content" catchtap="{{ap}}"><view class="modal-header"><text class="modal-title">时段详情</text><text class="modal-close" bindtap="{{ae}}">✕</text></view><view wx:if="{{af}}" class="modal-body"><view class="detail-date"><text class="detail-day">{{ag}}</text><text class="detail-hour">{{ah}}:00 - {{ai}}:00</text></view><view class="detail-grid"><view class="detail-card"><text class="detail-icon">📊</text><text class="detail-label">活动总量</text><text class="detail-value">{{aj}}</text></view><view class="detail-card"><text class="detail-icon">⚡</text><text class="detail-label">平均活动指数</text><text class="detail-value">{{ak}}</text></view><view class="detail-card"><text class="detail-icon">🏠</text><text class="detail-label">主要场景</text><text class="detail-value">{{al}}</text></view><view class="detail-card"><text class="detail-icon">🌡️</text><text class="detail-label">平均温度</text><text class="detail-value">{{am}}{{an}}</text></view></view><view class="detail-info"><text class="info-text">共 {{ao}} 条记录</text></view></view></view></view></view>
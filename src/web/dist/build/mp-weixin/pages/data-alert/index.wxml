<view class="page"><view class="status-bar" style="{{'padding-top:' + d}}"><view class="header"><view class="logo"><view class="back-btn" bindtap="{{a}}"><text>← 返回分析</text></view><text class="logo-icon">🔮</text><text class="app-name">AI智能预警</text></view><view class="header-actions"><view class="date-range" bindtap="{{c}}"><text class="date-text">{{b}}</text><text class="date-arrow">▼</text></view></view></view></view><view class="main-content"><view class="status-cards"><view class="{{['status-card', g && 'anomaly']}}"><text class="card-icon">{{e}}</text><view class="card-info"><text class="card-value">{{f}}</text><text class="card-label">今日状态</text></view></view><view class="status-card count"><text class="card-icon">🔴</text><view class="card-info"><text class="card-value">{{h}}</text><text class="card-label">异常点数</text></view></view><view class="status-card zscore"><text class="card-icon">📊</text><view class="card-info"><text class="card-value">{{i}}</text><text class="card-label">最高 z-score</text></view></view><view class="status-card time"><text class="card-icon">🕐</text><view class="card-info"><text class="card-value">{{j}}</text><text class="card-label">检测时间</text></view></view></view><view class="chart-card timeline-card"><view class="card-header"><text class="card-title">夜间异常时间线</text><view class="legend"><view class="legend-item"><view class="line" style="background:#3b82f6"></view>运动次数</view><view class="legend-item"><view class="line" style="background:#f59e0b"></view>z-score</view><view class="legend-item"><view class="line" style="background:#ef4444;stroke-dasharray:4,2"></view>异常阈值</view><view class="legend-item"><view class="dot" style="background:#ef4444"></view>异常点</view></view></view><view class="chart-body" bindtap="{{G}}"><view class="axis-left"><text wx:for="{{k}}" wx:for-item="label" wx:key="b" class="axis-label-left" style="{{'bottom:' + label.c}}">{{label.a}}</text></view><view class="chart-area"><svg wx:if="{{r}}" u-s="{{['d']}}" class="chart-svg" u-i="44723f87-0" bind:__l="__l" u-p="{{r}}"><line wx:for="{{l}}" wx:for-item="i" wx:key="a" u-i="{{i.b}}" bind:__l="__l" u-p="{{i.c}}"/><polyline wx:if="{{m}}" u-i="44723f87-2,44723f87-0" bind:__l="__l" u-p="{{m}}"/><polyline wx:if="{{n}}" u-i="44723f87-3,44723f87-0" bind:__l="__l" u-p="{{n}}"/><line wx:if="{{o}}" u-i="44723f87-4,44723f87-0" bind:__l="__l" u-p="{{o}}"/><circle wx:for="{{p}}" wx:for-item="pt" wx:key="a" u-i="{{pt.b}}" bind:__l="__l" u-p="{{pt.c}}"/><g wx:for="{{q}}" wx:for-item="item" wx:key="d" u-s="{{['d']}}" u-i="{{item.e}}" bind:__l="__l"><circle wx:if="{{item.c}}" class="clickable-point" catchclick="{{item.a}}" u-i="{{item.b}}" bind:__l="__l" u-p="{{item.c}}"/></g></svg><view wx:if="{{s}}" class="chart-tooltip" style="{{'left:' + C + ';' + ('top:' + D)}}"><view class="tooltip-header">{{t}}</view><view class="tooltip-row"><text class="tooltip-label">运动次数：</text><text class="tooltip-value">{{v}}</text></view><view class="tooltip-row"><text class="tooltip-label">z-score：</text><text class="{{['tooltip-value', x && 'high']}}">{{w}}</text></view><view class="tooltip-row"><text class="tooltip-label">活动指数：</text><text class="tooltip-value">{{y}}</text></view><view wx:if="{{z}}" class="tooltip-row"><text class="tooltip-label">温度：</text><text class="tooltip-value">{{A}}°C</text></view><view wx:if="{{B}}" class="tooltip-row"><text class="tooltip-label">状态：</text><text class="tooltip-value high">🚨 异常点</text></view></view></view><view class="axis-right"><text wx:for="{{E}}" wx:for-item="label" wx:key="b" class="axis-label-right" style="{{'bottom:' + label.c}}">{{label.a}}</text></view><view class="axis-bottom"><text wx:for="{{F}}" wx:for-item="label" wx:key="b" class="axis-label" style="{{'left:' + label.c}}">{{label.a}}</text></view></view></view><view class="chart-card list-card"><view class="card-header"><text class="card-title">异常点详情</text><text class="card-subtitle">共 {{H}} 条记录</text></view><scroll-view class="list-scroll" scroll-y><view wx:for="{{I}}" wx:for-item="item" wx:key="i" class="list-item"><view class="item-time"><text class="time-label">{{item.a}}</text><text class="time-value">{{item.b}}</text></view><view class="item-data"><view class="data-row"><text class="data-label">运动次数</text><text class="data-value">{{item.c}}</text></view><view class="data-row"><text class="data-label">z-score</text><text class="{{['data-value', item.e && 'high']}}">{{item.d}}</text></view><view class="data-row"><text class="data-label">活动指数</text><text class="data-value">{{item.f}}</text></view><view wx:if="{{item.g}}" class="data-row"><text class="data-label">温度</text><text class="data-value">{{item.h}}°C</text></view></view></view></scroll-view></view><view class="chart-card summary-card"><view class="card-header"><text class="card-title">每日异常汇总</text></view><view class="summary-body"><view class="summary-row header"><text class="summary-cell">日期</text><text class="summary-cell">异常点数</text><text class="summary-cell">最高z-score</text><text class="summary-cell">状态</text></view><view wx:for="{{J}}" wx:for-item="item" wx:key="g" class="summary-row"><text class="summary-cell">{{item.a}}</text><text class="{{['summary-cell', item.c && 'highlight']}}">{{item.b}}</text><text class="summary-cell">{{item.d}}</text><text class="summary-cell"><text class="{{item.f}}">{{item.e}}</text></text></view></view></view><view class="chart-card rules-card"><view class="card-header"><text class="card-title">预警规则说明</text></view><view class="rules-body"><view class="rule-item"><text class="rule-label">检测时段</text><text class="rule-value">22:00 ~ 06:00（夜间）</text></view><view class="rule-item"><text class="rule-label">统计窗口</text><text class="rule-value">5分钟（motion_5min_sum）</text></view><view class="rule-item"><text class="rule-label">异常阈值</text><text class="rule-value highlight">z-score > 2.5</text></view><view class="rule-item"><text class="rule-label">判定逻辑</text><text class="rule-value">单点 z-score 超过阈值即标记异常</text></view></view></view></view></view>
.page{min-height:100vh;background:linear-gradient(180deg,#0f172a,#1e293b);padding:0 16rpx 120rpx}@media (min-width: 768px){.page{margin-left:220px;padding:0 20px 40px;max-width:980px}}@media (min-width: 1200px){.page{margin-left:240px;max-width:1080px}}.status-bar{background:rgba(15,23,42,.98)}.header{display:flex;justify-content:space-between;align-items:center;padding:12rpx 0}.logo{display:flex;align-items:center;gap:10rpx}.logo-icon{font-size:32rpx}.app-name{font-size:28rpx;font-weight:700;color:#fff}.back-btn{background:rgba(255,255,255,.08);padding:8rpx 16rpx;border-radius:14rpx;font-size:22rpx;color:#94a3b8}.header-actions{display:flex;align-items:center;gap:10rpx}.date-range{display:flex;align-items:center;gap:6rpx;background:rgba(255,255,255,.1);padding:8rpx 16rpx;border-radius:16rpx}.date-text{font-size:22rpx;color:#fff}.date-arrow{font-size:16rpx;color:#94a3b8}.main-content{margin-top:12rpx;display:flex;flex-direction:column;gap:10rpx}.chart-card{background:rgba(255,255,255,.05);border-radius:14rpx;padding:16rpx;border:1rpx solid rgba(255,255,255,.05)}.card-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:10rpx}.card-title{font-size:24rpx;font-weight:700;color:#fff}.card-subtitle{font-size:18rpx;color:#64748b}.legend{display:flex;gap:12rpx}.legend-item{display:flex;align-items:center;gap:6rpx;font-size:18rpx;color:#94a3b8}.legend-item .line{width:20rpx;height:3rpx;border-radius:2rpx}.legend-item .dot{width:10rpx;height:10rpx;border-radius:50%}.status-cards{display:flex;gap:10rpx}.status-card{flex:1;min-width:110rpx;background:rgba(255,255,255,.05);border-radius:14rpx;padding:14rpx 10rpx;display:flex;flex-direction:column;align-items:center;gap:6rpx;border:1rpx solid rgba(255,255,255,.05)}.status-card.anomaly{border-color:rgba(239,68,68,.4);background:rgba(239,68,68,.1)}.status-card.count{border-color:rgba(239,68,68,.3)}.status-card.zscore{border-color:rgba(245,158,11,.3)}.card-icon{font-size:28rpx}.card-info{display:flex;flex-direction:column;align-items:center;gap:2rpx}.card-value{font-size:22rpx;font-weight:700;color:#fff}.card-label{font-size:18rpx;color:#94a3b8}.chart-body{position:relative;height:180rpx;display:flex;align-items:flex-start}.chart-area{position:relative;flex:1;height:150rpx}.axis-left{position:relative;width:48rpx;height:150rpx;flex-shrink:0}.axis-left .axis-label-left{position:absolute;font-size:14rpx;color:#64748b;text-align:right;padding-right:6rpx;transform:translateY(50%)}.axis-right{position:relative;width:48rpx;height:150rpx;flex-shrink:0}.axis-right .axis-label-right{position:absolute;font-size:14rpx;color:#64748b;text-align:left;padding-left:6rpx;transform:translateY(50%)}.chart-svg{position:absolute;top:0;left:0;width:100%;height:100%}.clickable-point{cursor:pointer}.chart-tooltip{position:absolute;background:rgba(15,23,42,.95);border:1rpx solid rgba(255,255,255,.1);border-radius:10rpx;padding:12rpx;z-index:100;min-width:180rpx;transform:translate(-50%,-100%) translateY(-8rpx);box-shadow:0 6rpx 24rpx rgba(0,0,0,.4)}.chart-tooltip:after{content:"";position:absolute;bottom:-6rpx;left:50%;transform:translate(-50%);border-left:6rpx solid transparent;border-right:6rpx solid transparent;border-top:6rpx solid rgba(255,255,255,.1)}.tooltip-header{font-size:22rpx;font-weight:700;color:#fff;margin-bottom:8rpx;padding-bottom:6rpx;border-bottom:1rpx solid rgba(255,255,255,.1)}.tooltip-row{display:flex;justify-content:space-between;align-items:center;gap:12rpx;margin-bottom:6rpx}.tooltip-label{font-size:20rpx;color:#94a3b8}.tooltip-value{font-size:20rpx;color:#cbd5e1;font-weight:700}.tooltip-value.high{color:#ef4444}.axis-bottom{position:absolute;bottom:0;left:48rpx;right:48rpx;height:30rpx}.axis-bottom .axis-label{position:absolute;transform:translate(-50%);font-size:16rpx;color:#64748b}.list-scroll{max-height:300rpx}.list-item{display:flex;gap:14rpx;padding:12rpx;background:rgba(255,255,255,.03);border-radius:10rpx;margin-bottom:10rpx}.list-item:last-child{margin-bottom:0}.item-time{width:84rpx;flex-shrink:0;display:flex;flex-direction:column;gap:2rpx}.time-label{font-size:16rpx;color:#64748b}.time-value{font-size:22rpx;font-weight:700;color:#fff}.item-data{flex:1;display:flex;flex-direction:column;gap:6rpx}.data-row{display:flex;justify-content:space-between;align-items:center}.data-label{font-size:20rpx;color:#94a3b8}.data-value{font-size:20rpx;color:#cbd5e1}.data-value.high{color:#ef4444;font-weight:700}.summary-body{display:flex;flex-direction:column}.summary-row{display:flex;border-bottom:1rpx solid rgba(255,255,255,.05)}.summary-row:last-child{border-bottom:none}.summary-row.header{background:rgba(255,255,255,.05)}.summary-cell{flex:1;padding:12rpx 6rpx;font-size:20rpx;text-align:center;color:#cbd5e1}.summary-cell.highlight{color:#ef4444;font-weight:700}.summary-cell .anomalous{color:#ef4444}.summary-cell .normal{color:#22c55e}.summary-row.header .summary-cell{font-weight:700;color:#94a3b8}.rules-body{display:flex;flex-direction:column;gap:12rpx}.rule-item{display:flex;justify-content:space-between;align-items:center;padding:10rpx 14rpx;background:rgba(255,255,255,.03);border-radius:10rpx}.rule-label{font-size:22rpx;color:#94a3b8}.rule-value{font-size:22rpx;color:#cbd5e1}.rule-value.highlight{color:#ef4444;font-weight:700}

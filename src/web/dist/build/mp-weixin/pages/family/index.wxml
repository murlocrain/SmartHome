<view class="page" style="{{'background:' + y}}"><view class="nav-bar" style="{{'background:' + b}}"><text class="nav-title" style="{{'color:' + a}}">家庭管理</text></view><view class="page-header"><text class="page-title" style="{{'color:' + c}}">选择家庭</text><text class="page-desc" style="{{'color:' + d}}">请先创建或选择一个家庭</text></view><view wx:if="{{e}}" class="family-list"><view wx:for="{{f}}" wx:for-item="family" wx:key="c" class="family-card" style="{{'background:' + j}}" bindtap="{{family.d}}"><view class="family-icon">🏠</view><view class="family-info"><text class="family-name" style="{{'color:' + g}}">{{family.a}}</text><text class="family-desc" style="{{'color:' + h}}">创建于 {{family.b}}</text></view><view class="family-arrow" style="{{'color:' + i}}">›</view></view></view><view wx:else class="empty-state" style="{{'background:' + m}}"><text class="empty-icon">🏠</text><text class="empty-text" style="{{'color:' + k}}">还没有创建家庭</text><text class="empty-desc" style="{{'color:' + l}}">点击下方按钮创建您的第一个家庭</text></view><view class="create-section"><view class="input-group" style="{{'background:' + s}}"><view class="input-label" style="{{'color:' + n}}">家庭名称</view><input class="input-field" style="{{'background:' + o + ';' + ('color:' + p)}}" type="text" placeholder="请输入家庭名称" placeholder-class="placeholder" value="{{q}}" bindinput="{{r}}"/></view><button class="create-btn" style="{{'background:' + v}}" bindtap="{{w}}" disabled="{{x}}"><text class="create-text" style="{{'color:' + '#fff'}}">{{t}}</text></button></view></view>